# ─── REQUIRED ────────────────────────────────────────────────

# PostgreSQL connection.
# - For Supabase: use the transaction pooler (port 6543) with pgbouncer params.
#   connection_limit=1 is correct for serverless (Vercel). For long-running Node
#   servers (Railway/Render/Fly), bump to 10-20.
DATABASE_URL="postgresql://user:password@host:6543/dbname?pgbouncer=true&connection_limit=1"

# Used by `prisma migrate` (needs a non-pgbouncer connection). Same database,
# direct port 5432 / session pooler.
DIRECT_URL="postgresql://user:password@host:5432/dbname"

# Auth.js v5 signing secret. Generate one with:  npx auth secret
# DO NOT reuse the dev value in production. Set this in your hosting platform's
# environment variables, not in a committed file.
AUTH_SECRET=""

# Optional. Auth.js infers from request headers when trustHost=true (default
# in this app). Only set if you need to force a specific origin.
# AUTH_URL="https://your-domain.com"

# ─── UPLOADS ─────────────────────────────────────────────────

UPLOADTHING_TOKEN=""

# ─── PRODUCTION SEED (optional) ──────────────────────────────

# The seed script (prisma/seed.ts) refuses to run in NODE_ENV=production
# unless SEED_ALLOW_PRODUCTION=true. Even then, demo data (sample courses,
# students, teacher, hardware kits, announcements) will NOT be created.
# Only the bootstrap admin user is created from the env vars below.
#
# SEED_ALLOW_PRODUCTION=true
# ADMIN_EMAIL=admin@yourcompany.com
# ADMIN_PASSWORD=<long-random-string>
# ADMIN_NAME="Site Administrator"
